# Expo / React Native — not started by Docker Compose.
# Copy: cp .env.example .env

# Production API (release builds; also baked into app.config extra via EAS env)
EXPO_PUBLIC_BACKEND_URL=https://your-api.example.com

# Optional: logical env for extra.environment (development | preview | production)
# EAS profiles set EXPO_PUBLIC_APP_ENV; local dev can omit.
# EXPO_PUBLIC_APP_ENV=development

# Development: full URL to API (use machine LAN IP + nginx port when API is in Docker)
# Example: http://192.168.1.10:80  (same as school-erp-infra HTTP_PORT)
EXPO_PUBLIC_BACKEND_URL_DEV=http://localhost:80

# Or build dev URL from IP + port:
EXPO_PUBLIC_LOCAL_IP=192.168.1.100
EXPO_PUBLIC_DEV_PORT=80
